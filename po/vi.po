#: src/frontend/keysclicks-feedback.c:303
msgid "Screenshot attached."
msgstr "Đã đính kèm ảnh chụp màn hình."

#: src/frontend/keysclicks-feedback.c:307
msgid "Screenshot unavailable — your description still helps."
msgstr "Không có ảnh chụp màn hình — mô tả của bạn vẫn hữu ích."

#: src/frontend/keysclicks-feedback.c:414
#, c-format
msgid "Report #%s sent — thank you!"
msgstr "Đã gửi Báo cáo #%s — cảm ơn bạn!"

#: src/frontend/keysclicks-feedback.c:416
msgid "Report sent — thank you!"
msgstr "Đã gửi báo cáo — cảm ơn bạn!"

#: src/frontend/keysclicks-feedback.c:424
msgid "Could not send your report."
msgstr "Không thể gửi báo cáo của bạn."

#: src/frontend/keysclicks-feedback.c:428
msgid "Network error — please try again."
msgstr "Lỗi mạng — vui lòng thử lại."

#: src/frontend/keysclicks-feedback.c:451
msgid "Capturing screenshot…"
msgstr "Đang chụp màn hình…"

#: src/frontend/keysclicks-feedback.c:502
msgid "Sending…"
msgstr "Đang gửi…"

#: src/frontend/keysclicks-feedback.c:541
#: src/frontend/keysclicks-feedback.c:557
msgid "Report a bug or idea"
msgstr "Báo lỗi hoặc ý tưởng"

#: src/frontend/keysclicks-feedback.c:565
msgid "🐞 Bug"
msgstr "🐞 Lỗi"

#: src/frontend/keysclicks-feedback.c:566
msgid "💡 Idea"
msgstr "💡 Ý tưởng"

#: src/frontend/keysclicks-feedback.c:574
msgid "What happened? (optional)"
msgstr "Đã xảy ra chuyện gì? (tùy chọn)"

#: src/frontend/keysclicks-feedback.c:593
msgid "Attach screenshot of my screen"
msgstr "Đính kèm ảnh chụp màn hình của tôi"

#: src/frontend/keysclicks-feedback.c:598
msgid "A screenshot may show sensitive on-screen content. Off by default."
msgstr ""
"Ảnh chụp màn hình có thể hiển thị nội dung nhạy cảm trên màn hình. Tắt theo "
"mặc định."

#: src/frontend/keysclicks-feedback.c:612
msgid "Attach diagnostics (build, OS, monitors)"
msgstr "Đính kèm thông tin chẩn đoán (bản dựng, HĐH, màn hình)"

#: src/frontend/keysclicks-feedback.c:626
msgid "Cancel"
msgstr "Hủy"

#: src/frontend/keysclicks-feedback.c:628
msgid "Send"
msgstr "Gửi"

#: src/frontend/keysclicks-feedback.c:651
msgid "Report a bug"
msgstr "Báo lỗi"

#: src/frontend/keysclicks-overlay.c:404
msgid "On-Screen Keys & Clicks Visualizer"
msgstr "Trình hiển thị Phím & Nhấp chuột trên màn hình"

#: src/frontend/keysclicks-window.c:141
msgid "Close to switch monitor"
msgstr "Đóng để chuyển màn hình"

#: src/frontend/keysclicks-window.c:142
msgid ""
"The overlay moves to the new monitor the next time you open the app. Your "
"settings are already saved — closing now is safe."
msgstr ""
"Lớp phủ sẽ chuyển sang màn hình mới vào lần tiếp theo bạn mở ứng dụng. Cài "
"đặt của bạn đã được lưu — đóng bây giờ là an toàn."

#: src/frontend/keysclicks-window.c:152
msgid "Close"
msgstr "Đóng"

#. Language --------------------------------------------------------------
#: src/frontend/keysclicks-window.c:521 src/frontend/keysclicks-window.c:932
msgid "Language"
msgstr "Ngôn ngữ"

#: src/frontend/keysclicks-window.c:532 src/frontend/keysclicks-window.c:580
msgid "System (default)"
msgstr "Hệ thống (mặc định)"

#: src/frontend/keysclicks-window.c:562
msgid "Keyboard layout"
msgstr "Bố cục bàn phím"

#: src/frontend/keysclicks-window.c:630
msgid "Automatic"
msgstr "Tự động"

#: src/frontend/keysclicks-window.c:636
#, c-format
msgid "Monitor %u"
msgstr "Màn hình %u"

#: src/frontend/keysclicks-window.c:655
msgid "Overlay monitor"
msgstr "Màn hình hiển thị lớp phủ"

#: src/frontend/keysclicks-window.c:686
msgid "Pin to dock"
msgstr "Ghim vào dock"

#: src/frontend/keysclicks-window.c:686
msgid "Unpin from dock"
msgstr "Bỏ ghim khỏi dock"

#: src/frontend/keysclicks-window.c:688
msgid "Remove this app from the COSMIC dock"
msgstr "Xóa ứng dụng này khỏi dock COSMIC"

#: src/frontend/keysclicks-window.c:689
msgid "Pin this app to the COSMIC dock"
msgstr "Ghim ứng dụng này vào dock COSMIC"

#: src/frontend/keysclicks-window.c:727
msgid "None — click Set, then hold a shortcut (e.g. Ctrl+Shift+H)"
msgstr "Không có — nhấn Đặt, rồi giữ một phím tắt (ví dụ Ctrl+Shift+H)"

#: src/frontend/keysclicks-window.c:755 src/frontend/keysclicks-window.c:834
msgid "Press keys…"
msgstr "Nhấn phím…"

#: src/frontend/keysclicks-window.c:755 src/frontend/keysclicks-window.c:969
msgid "Set"
msgstr "Đặt"

#: src/frontend/keysclicks-window.c:785
msgid "Hold the shortcut…  "
msgstr "Giữ phím tắt…  "

#: src/frontend/keysclicks-window.c:833
msgid "Hold the shortcut, then release to save. Esc cancels."
msgstr "Giữ phím tắt, rồi thả ra để lưu. Esc để hủy."

#: src/frontend/keysclicks-window.c:877 src/frontend/keysclicks-window.c:890
msgid ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"
msgstr ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"

#. Privacy master toggle, prominent on the left of the header.
#: src/frontend/keysclicks-window.c:895
msgid "Hide keys"
msgstr "Ẩn phím"

#: src/frontend/keysclicks-window.c:898
msgid "Hide keystrokes (privacy): show • instead of keys"
msgstr "Ẩn thao tác gõ phím (quyền riêng tư): hiển thị • thay vì phím"

#. overlay display layout, right below
#. Privacy ---------------------------------------------------------------
#: src/frontend/keysclicks-window.c:937
msgid "Privacy"
msgstr "Quyền riêng tư"

#: src/frontend/keysclicks-window.c:939
msgid "Hide keystrokes (privacy)"
msgstr "Ẩn thao tác gõ phím (quyền riêng tư)"

#: src/frontend/keysclicks-window.c:948
msgid "Automatic password hiding"
msgstr "Tự động ẩn mật khẩu"

#: src/frontend/keysclicks-window.c:956
msgid ""
"On (PRO) — passwords are hidden automatically in password fields. This "
"module is still in development."
msgstr ""
"Bật (PRO) — mật khẩu được tự động ẩn trong các trường mật khẩu. Mô-đun này "
"vẫn đang được phát triển."

#: src/frontend/keysclicks-window.c:958
msgid ""
"PRO — in development. Automatic hiding ships with the PRO add-on; the manual "
"\"Hide keys\" toggle/shortcut works now."
msgstr ""
"PRO — đang phát triển. Tính năng ẩn tự động đi kèm với gói bổ trợ PRO; nút/"
"phím tắt \"Hide keys\" thủ công đã hoạt động ngay bây giờ."

#: src/frontend/keysclicks-window.c:967
msgid "Hide-keys shortcut"
msgstr "Phím tắt ẩn phím"

#: src/frontend/keysclicks-window.c:972
msgid "Click, then hold a key combination to assign it"
msgstr "Nhấp, rồi giữ một tổ hợp phím để gán"

#: src/frontend/keysclicks-window.c:981
msgid "System keyboard shortcuts"
msgstr "Phím tắt bàn phím hệ thống"

#: src/frontend/keysclicks-window.c:984
msgid "Global shortcuts are set in the OS — open COSMIC → Keyboard → Shortcuts"
msgstr ""
"Phím tắt toàn cục được đặt trong HĐH — mở COSMIC → Keyboard → Shortcuts"

#: src/frontend/keysclicks-window.c:986
msgid "Open settings"
msgstr "Mở cài đặt"

#. Keys & clicks display -------------------------------------------------
#: src/frontend/keysclicks-window.c:993
msgid "Keys and clicks display"
msgstr "Hiển thị phím và nhấp chuột"

#: src/frontend/keysclicks-window.c:994
msgid "Compact"
msgstr "Nhỏ gọn"

#: src/frontend/keysclicks-window.c:994
msgid "Composed"
msgstr "Kết hợp"

#: src/frontend/keysclicks-window.c:994
msgid "Raw"
msgstr "Thô"

#: src/frontend/keysclicks-window.c:995
msgid "Label style"
msgstr "Kiểu nhãn"

#: src/frontend/keysclicks-window.c:996
msgid "Font size"
msgstr "Cỡ chữ"

#: src/frontend/keysclicks-window.c:997
msgid "Show keyboard"
msgstr "Hiển thị bàn phím"

#: src/frontend/keysclicks-window.c:999
msgid "Show mouse"
msgstr "Hiển thị chuột"

#: src/frontend/keysclicks-window.c:1000
msgid "Show Shift separately"
msgstr "Hiển thị Shift riêng"

#: src/frontend/keysclicks-window.c:1002
msgid "Draw border"
msgstr "Vẽ viền"

#. Position & behaviour --------------------------------------------------
#: src/frontend/keysclicks-window.c:1005
msgid "Position and behaviour"
msgstr "Vị trí và hành vi"

#: src/frontend/keysclicks-window.c:1006
msgid "Bottom"
msgstr "Dưới"

#: src/frontend/keysclicks-window.c:1006
msgid "Top"
msgstr "Trên"

#: src/frontend/keysclicks-window.c:1007
msgid "Screen edge"
msgstr "Cạnh màn hình"

#. Margins are PERCENT (zoom/resolution independent). Horizontal is bidirectional.
#: src/frontend/keysclicks-window.c:1009
msgid "Horizontal margin (%)"
msgstr "Lề ngang (%)"

#: src/frontend/keysclicks-window.c:1011
msgid "Vertical margin (%)"
msgstr "Lề dọc (%)"

#: src/frontend/keysclicks-window.c:1014
msgid "Keep visible (no timeout)"
msgstr "Luôn hiển thị (không hết giờ)"

#: src/frontend/keysclicks-window.c:1017
msgid "Timeout (ms)"
msgstr "Thời gian chờ (ms)"

#: src/frontend/keysclicks-window.c:1020
msgid "Bar opacity (%)"
msgstr "Độ mờ thanh (%)"

#: src/frontend/main.c:107
msgid "Left Click"
msgstr "Nhấp trái"

#: src/frontend/main.c:109
msgid "Right Click"
msgstr "Nhấp phải"

#: src/frontend/main.c:111
msgid "Middle Click"
msgstr "Nhấp giữa"

#: src/frontend/main.c:123
#, c-format
msgid "Mouse(%u)"
msgstr "Chuột(%u)"

#: src/frontend/main.c:418
msgid "Start without opening the settings window"
msgstr "Khởi động mà không mở cửa sổ cài đặt"

