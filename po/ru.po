#: src/frontend/keysclicks-feedback.c:303
msgid "Screenshot attached."
msgstr "Снимок экрана прикреплён."

#: src/frontend/keysclicks-feedback.c:307
msgid "Screenshot unavailable — your description still helps."
msgstr "Снимок экрана недоступен — ваше описание всё равно поможет."

#: src/frontend/keysclicks-feedback.c:414
#, c-format
msgid "Report #%s sent — thank you!"
msgstr "Отчёт #%s отправлен — спасибо!"

#: src/frontend/keysclicks-feedback.c:416
msgid "Report sent — thank you!"
msgstr "Отчёт отправлен — спасибо!"

#: src/frontend/keysclicks-feedback.c:424
msgid "Could not send your report."
msgstr "Не удалось отправить отчёт."

#: src/frontend/keysclicks-feedback.c:428
msgid "Network error — please try again."
msgstr "Ошибка сети — попробуйте ещё раз."

#: src/frontend/keysclicks-feedback.c:451
msgid "Capturing screenshot…"
msgstr "Создание снимка экрана…"

#: src/frontend/keysclicks-feedback.c:502
msgid "Sending…"
msgstr "Отправка…"

#: src/frontend/keysclicks-feedback.c:541
#: src/frontend/keysclicks-feedback.c:557
msgid "Report a bug or idea"
msgstr "Сообщить об ошибке или идее"

#: src/frontend/keysclicks-feedback.c:565
msgid "🐞 Bug"
msgstr "🐞 Ошибка"

#: src/frontend/keysclicks-feedback.c:566
msgid "💡 Idea"
msgstr "💡 Идея"

#: src/frontend/keysclicks-feedback.c:574
msgid "What happened? (optional)"
msgstr "Что произошло? (необязательно)"

#: src/frontend/keysclicks-feedback.c:593
msgid "Attach screenshot of my screen"
msgstr "Прикрепить снимок моего экрана"

#: src/frontend/keysclicks-feedback.c:598
msgid "A screenshot may show sensitive on-screen content. Off by default."
msgstr ""
"Снимок экрана может содержать конфиденциальную информацию с экрана. По "
"умолчанию выключено."

#: src/frontend/keysclicks-feedback.c:612
msgid "Attach diagnostics (build, OS, monitors)"
msgstr "Прикрепить диагностику (сборка, ОС, мониторы)"

#: src/frontend/keysclicks-feedback.c:626
msgid "Cancel"
msgstr "Отмена"

#: src/frontend/keysclicks-feedback.c:628
msgid "Send"
msgstr "Отправить"

#: src/frontend/keysclicks-feedback.c:651
msgid "Report a bug"
msgstr "Сообщить об ошибке"

#: src/frontend/keysclicks-overlay.c:404
msgid "On-Screen Keys & Clicks Visualizer"
msgstr "Экранный визуализатор клавиш и кликов"

#: src/frontend/keysclicks-window.c:142
msgid "Close to switch monitor"
msgstr "Закройте, чтобы сменить монитор"

#: src/frontend/keysclicks-window.c:143
msgid ""
"The overlay moves to the new monitor the next time you open the app. Your "
"settings are already saved — closing now is safe."
msgstr ""
"Оверлей переместится на новый монитор при следующем открытии приложения. "
"Ваши настройки уже сохранены — закрывать сейчас безопасно."

#: src/frontend/keysclicks-window.c:153 src/frontend/keysclicks-window.c:181
msgid "Close"
msgstr "Закрыть"

#: src/frontend/keysclicks-window.c:170
msgid "Close to switch language"
msgstr "Закройте, чтобы сменить язык"

#: src/frontend/keysclicks-window.c:171
msgid ""
"The overlay switches to the new language the next time you open the app. "
"Your settings are already saved — closing now is safe."
msgstr ""
"Оверлей переключится на новый язык при следующем открытии приложения. Ваши "
"настройки уже сохранены — закрывать сейчас безопасно."

#. Language --------------------------------------------------------------
#: src/frontend/keysclicks-window.c:561 src/frontend/keysclicks-window.c:972
msgid "Language"
msgstr "Язык"

#: src/frontend/keysclicks-window.c:572 src/frontend/keysclicks-window.c:620
msgid "System (default)"
msgstr "Системный (по умолчанию)"

#: src/frontend/keysclicks-window.c:602
msgid "Keyboard layout"
msgstr "Раскладка клавиатуры"

#: src/frontend/keysclicks-window.c:670
msgid "Automatic"
msgstr "Автоматически"

#: src/frontend/keysclicks-window.c:676
#, c-format
msgid "Monitor %u"
msgstr "Монитор %u"

#: src/frontend/keysclicks-window.c:695
msgid "Overlay monitor"
msgstr "Монитор оверлея"

#: src/frontend/keysclicks-window.c:726
msgid "Pin to dock"
msgstr "Закрепить в доке"

#: src/frontend/keysclicks-window.c:726
msgid "Unpin from dock"
msgstr "Открепить из дока"

#: src/frontend/keysclicks-window.c:728
msgid "Remove this app from the COSMIC dock"
msgstr "Удалить это приложение из дока COSMIC"

#: src/frontend/keysclicks-window.c:729
msgid "Pin this app to the COSMIC dock"
msgstr "Закрепить это приложение в доке COSMIC"

#: src/frontend/keysclicks-window.c:767
msgid "None — click Set, then hold a shortcut (e.g. Ctrl+Shift+H)"
msgstr ""
"Не задано — нажмите «Задать», затем удерживайте сочетание (например, "
"Ctrl+Shift+H)"

#: src/frontend/keysclicks-window.c:795 src/frontend/keysclicks-window.c:874
msgid "Press keys…"
msgstr "Нажмите клавиши…"

#: src/frontend/keysclicks-window.c:795 src/frontend/keysclicks-window.c:1009
msgid "Set"
msgstr "Задать"

#: src/frontend/keysclicks-window.c:825
msgid "Hold the shortcut…  "
msgstr "Удерживайте сочетание…  "

#: src/frontend/keysclicks-window.c:873
msgid "Hold the shortcut, then release to save. Esc cancels."
msgstr "Удерживайте сочетание, затем отпустите для сохранения. Esc — отмена."

#: src/frontend/keysclicks-window.c:917 src/frontend/keysclicks-window.c:930
msgid ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"
msgstr ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"

#. Privacy master toggle, prominent on the left of the header.
#: src/frontend/keysclicks-window.c:935
msgid "Hide keys"
msgstr "Скрыть клавиши"

#: src/frontend/keysclicks-window.c:938
msgid "Hide keystrokes (privacy): show • instead of keys"
msgstr "Скрыть нажатия (приватность): показывать • вместо клавиш"

#. overlay display layout, right below
#. Privacy ---------------------------------------------------------------
#: src/frontend/keysclicks-window.c:977
msgid "Privacy"
msgstr "Приватность"

#: src/frontend/keysclicks-window.c:979
msgid "Hide keystrokes (privacy)"
msgstr "Скрыть нажатия (приватность)"

#: src/frontend/keysclicks-window.c:988
msgid "Automatic password hiding"
msgstr "Автоматическое скрытие паролей"

#: src/frontend/keysclicks-window.c:996
msgid ""
"On (PRO) — passwords are hidden automatically in password fields. This "
"module is still in development."
msgstr ""
"Вкл (PRO) — пароли автоматически скрываются в полях ввода пароля. Этот "
"модуль ещё в разработке."

#: src/frontend/keysclicks-window.c:998
msgid ""
"PRO — in development. Automatic hiding ships with the PRO add-on; the manual "
"\"Hide keys\" toggle/shortcut works now."
msgstr ""
"PRO — в разработке. Автоматическое скрытие входит в дополнение PRO; ручной "
"переключатель/сочетание \"Hide keys\" работает уже сейчас."

#: src/frontend/keysclicks-window.c:1007
msgid "Hide-keys shortcut"
msgstr "Сочетание для скрытия клавиш"

#: src/frontend/keysclicks-window.c:1012
msgid "Click, then hold a key combination to assign it"
msgstr "Нажмите, затем удерживайте сочетание клавиш, чтобы назначить его"

#: src/frontend/keysclicks-window.c:1021
msgid "System keyboard shortcuts"
msgstr "Системные сочетания клавиш"

#: src/frontend/keysclicks-window.c:1024
msgid "Global shortcuts are set in the OS — open COSMIC → Keyboard → Shortcuts"
msgstr ""
"Глобальные сочетания задаются в ОС — откройте COSMIC → Клавиатура → Сочетания"

#: src/frontend/keysclicks-window.c:1026
msgid "Open settings"
msgstr "Открыть настройки"

#. Keys & clicks display -------------------------------------------------
#: src/frontend/keysclicks-window.c:1033
msgid "Keys and clicks display"
msgstr "Отображение клавиш и кликов"

#. Master on/off for the on-screen overlay bar (turn it off without quitting).
#: src/frontend/keysclicks-window.c:1035
msgid "Show overlay"
msgstr "Показывать оверлей"

#: src/frontend/keysclicks-window.c:1037
msgid "Compact"
msgstr "Компактный"

#: src/frontend/keysclicks-window.c:1037
msgid "Composed"
msgstr "Составной"

#: src/frontend/keysclicks-window.c:1037
msgid "Raw"
msgstr "Исходный"

#: src/frontend/keysclicks-window.c:1038
msgid "Label style"
msgstr "Стиль подписей"

#: src/frontend/keysclicks-window.c:1039
msgid "Font size"
msgstr "Размер шрифта"

#: src/frontend/keysclicks-window.c:1040
msgid "Show keyboard"
msgstr "Показывать клавиатуру"

#: src/frontend/keysclicks-window.c:1042
msgid "Show mouse"
msgstr "Показывать мышь"

#: src/frontend/keysclicks-window.c:1043
msgid "Show Shift separately"
msgstr "Показывать Shift отдельно"

#: src/frontend/keysclicks-window.c:1045
msgid "Draw border"
msgstr "Рисовать рамку"

#. Position & behaviour --------------------------------------------------
#: src/frontend/keysclicks-window.c:1048
msgid "Position and behaviour"
msgstr "Положение и поведение"

#: src/frontend/keysclicks-window.c:1049
msgid "Bottom"
msgstr "Снизу"

#: src/frontend/keysclicks-window.c:1049
msgid "Top"
msgstr "Сверху"

#: src/frontend/keysclicks-window.c:1050
msgid "Screen edge"
msgstr "Край экрана"

#. Margins are PERCENT (zoom/resolution independent). Horizontal is bidirectional.
#: src/frontend/keysclicks-window.c:1052
msgid "Horizontal margin (%)"
msgstr "Горизонтальный отступ (%)"

#: src/frontend/keysclicks-window.c:1054
msgid "Vertical margin (%)"
msgstr "Вертикальный отступ (%)"

#: src/frontend/keysclicks-window.c:1057
msgid "Keep visible (no timeout)"
msgstr "Всегда показывать (без таймаута)"

#: src/frontend/keysclicks-window.c:1060
msgid "Timeout (ms)"
msgstr "Таймаут (ms)"

#: src/frontend/keysclicks-window.c:1063
msgid "Bar opacity (%)"
msgstr "Непрозрачность панели (%)"

#: src/frontend/main.c:107
msgid "Left Click"
msgstr "Левый клик"

#: src/frontend/main.c:109
msgid "Right Click"
msgstr "Правый клик"

#: src/frontend/main.c:111
msgid "Middle Click"
msgstr "Средний клик"

#: src/frontend/main.c:123
#, c-format
msgid "Mouse(%u)"
msgstr "Мышь(%u)"

