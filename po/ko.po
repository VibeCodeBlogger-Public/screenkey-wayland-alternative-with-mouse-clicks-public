msgid "Keyboard layout"
msgstr "키보드 레이아웃"

#: src/frontend/keysclicks-window.c:664
msgid "Automatic"
msgstr "자동"

#: src/frontend/keysclicks-window.c:670
#, c-format
msgid "Monitor %u"
msgstr "모니터 %u"

#: src/frontend/keysclicks-window.c:689
msgid "Overlay monitor"
msgstr "오버레이 모니터"

#: src/frontend/keysclicks-window.c:720
msgid "Pin to dock"
msgstr "독에 고정"

#: src/frontend/keysclicks-window.c:720
msgid "Unpin from dock"
msgstr "독에서 고정 해제"

#: src/frontend/keysclicks-window.c:722
msgid "Remove this app from the COSMIC dock"
msgstr "이 앱을 COSMIC 독에서 제거"

#: src/frontend/keysclicks-window.c:723
msgid "Pin this app to the COSMIC dock"
msgstr "이 앱을 COSMIC 독에 고정"

#: src/frontend/keysclicks-window.c:761
msgid "None — click Set, then hold a shortcut (e.g. Ctrl+Shift+H)"
msgstr "없음 — 설정을 클릭한 다음 단축키를 길게 누르세요 (예: Ctrl+Shift+H)"

#: src/frontend/keysclicks-window.c:789 src/frontend/keysclicks-window.c:868
msgid "Press keys…"
msgstr "키를 누르세요…"

#: src/frontend/keysclicks-window.c:789 src/frontend/keysclicks-window.c:1003
msgid "Set"
msgstr "설정"

#: src/frontend/keysclicks-window.c:819
msgid "Hold the shortcut…  "
msgstr "단축키를 길게 누르세요…  "

#: src/frontend/keysclicks-window.c:867
msgid "Hold the shortcut, then release to save. Esc cancels."
msgstr "단축키를 길게 누른 다음 손을 떼면 저장됩니다. Esc를 누르면 취소됩니다."

#: src/frontend/keysclicks-window.c:911 src/frontend/keysclicks-window.c:924
msgid ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"
msgstr ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"

#. Privacy master toggle, prominent on the left of the header.
#: src/frontend/keysclicks-window.c:929
msgid "Hide keys"
msgstr "키 숨기기"

#: src/frontend/keysclicks-window.c:932
msgid "Hide keystrokes (privacy): show • instead of keys"
msgstr "키 입력 숨기기 (개인정보 보호): 키 대신 • 표시"

#. overlay display layout, right below
#. Privacy ---------------------------------------------------------------
#: src/frontend/keysclicks-window.c:971
msgid "Privacy"
msgstr "개인정보 보호"

#: src/frontend/keysclicks-window.c:973
msgid "Hide keystrokes (privacy)"
msgstr "키 입력 숨기기 (개인정보 보호)"

#: src/frontend/keysclicks-window.c:982
msgid "Automatic password hiding"
msgstr "자동 비밀번호 숨기기"

#: src/frontend/keysclicks-window.c:990
msgid ""
"On (PRO) — passwords are hidden automatically in password fields. This "
"module is still in development."
msgstr ""
"켜짐 (PRO) — 비밀번호 필드에서 비밀번호가 자동으로 숨겨집니다. 이 모듈은 아"
"직 개발 중입니다."

#: src/frontend/keysclicks-window.c:992
msgid ""
"PRO — in development. Automatic hiding ships with the PRO add-on; the manual "
"\"Hide keys\" toggle/shortcut works now."
msgstr ""
"PRO — 개발 중. 자동 숨기기는 PRO 추가 기능과 함께 제공됩니다. 수동 \"Hide "
"keys\" 토글/단축키는 지금 작동합니다."

#: src/frontend/keysclicks-window.c:1001
msgid "Hide-keys shortcut"
msgstr "키 숨기기 단축키"

#: src/frontend/keysclicks-window.c:1006
msgid "Click, then hold a key combination to assign it"
msgstr "클릭한 다음 키 조합을 길게 눌러 지정하세요"

#: src/frontend/keysclicks-window.c:1015
msgid "System keyboard shortcuts"
msgstr "시스템 키보드 단축키"

#: src/frontend/keysclicks-window.c:1018
msgid "Global shortcuts are set in the OS — open COSMIC → Keyboard → Shortcuts"
msgstr "전역 단축키는 OS에서 설정합니다 — COSMIC → 키보드 → 단축키를 여세요"

#: src/frontend/keysclicks-window.c:1020
msgid "Open settings"
msgstr "설정 열기"

