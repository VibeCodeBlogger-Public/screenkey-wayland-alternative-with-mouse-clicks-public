#: src/frontend/keysclicks-feedback.c:303
msgid "Screenshot attached."
msgstr "لقطة الشاشة مرفقة."

#: src/frontend/keysclicks-feedback.c:307
msgid "Screenshot unavailable — your description still helps."
msgstr "لقطة الشاشة غير متاحة — وصفك يظل مفيدًا."

#: src/frontend/keysclicks-feedback.c:414
#, c-format
msgid "Report #%s sent — thank you!"
msgstr "تم إرسال التقرير رقم %s — شكرًا لك!"

#: src/frontend/keysclicks-feedback.c:416
msgid "Report sent — thank you!"
msgstr "تم إرسال التقرير — شكرًا لك!"

#: src/frontend/keysclicks-feedback.c:424
msgid "Could not send your report."
msgstr "تعذّر إرسال تقريرك."

#: src/frontend/keysclicks-feedback.c:428
msgid "Network error — please try again."
msgstr "خطأ في الشبكة — يرجى المحاولة مرة أخرى."

#: src/frontend/keysclicks-feedback.c:451
msgid "Capturing screenshot…"
msgstr "جارٍ التقاط لقطة الشاشة…"

#: src/frontend/keysclicks-feedback.c:502
msgid "Sending…"
msgstr "جارٍ الإرسال…"

#: src/frontend/keysclicks-feedback.c:541
#: src/frontend/keysclicks-feedback.c:557
msgid "Report a bug or idea"
msgstr "الإبلاغ عن خطأ أو فكرة"

#: src/frontend/keysclicks-feedback.c:565
msgid "🐞 Bug"
msgstr "🐞 خطأ"

#: src/frontend/keysclicks-feedback.c:566
msgid "💡 Idea"
msgstr "💡 فكرة"

#: src/frontend/keysclicks-feedback.c:574
msgid "What happened? (optional)"
msgstr "ماذا حدث؟ (اختياري)"

#: src/frontend/keysclicks-feedback.c:593
msgid "Attach screenshot of my screen"
msgstr "إرفاق لقطة لشاشتي"

#: src/frontend/keysclicks-feedback.c:598
msgid "A screenshot may show sensitive on-screen content. Off by default."
msgstr "قد تُظهر لقطة الشاشة محتوى حسّاسًا معروضًا. مُعطّلة افتراضيًا."

#: src/frontend/keysclicks-feedback.c:612
msgid "Attach diagnostics (build, OS, monitors)"
msgstr "إرفاق بيانات التشخيص (الإصدار، نظام التشغيل، الشاشات)"

#: src/frontend/keysclicks-feedback.c:626
msgid "Cancel"
msgstr "إلغاء"

#: src/frontend/keysclicks-feedback.c:628
msgid "Send"
msgstr "إرسال"

#: src/frontend/keysclicks-feedback.c:651
msgid "Report a bug"
msgstr "الإبلاغ عن خطأ"

#: src/frontend/keysclicks-overlay.c:404
msgid "On-Screen Keys & Clicks Visualizer"
msgstr "مُصوِّر المفاتيح والنقرات على الشاشة"

#: src/frontend/keysclicks-window.c:142
msgid "Close to switch monitor"
msgstr "أغلِق للتبديل بين الشاشات"

#: src/frontend/keysclicks-window.c:143
msgid ""
"The overlay moves to the new monitor the next time you open the app. Your "
"settings are already saved — closing now is safe."
msgstr ""
"تنتقل الطبقة إلى الشاشة الجديدة في المرة التالية التي تفتح فيها التطبيق. تم "
"حفظ إعداداتك بالفعل — الإغلاق الآن آمن."

#: src/frontend/keysclicks-window.c:153 src/frontend/keysclicks-window.c:181
msgid "Close"
msgstr "إغلاق"

#: src/frontend/keysclicks-window.c:170
msgid "Close to switch language"
msgstr "أغلِق لتبديل اللغة"

#: src/frontend/keysclicks-window.c:171
msgid ""
"The overlay switches to the new language the next time you open the app. "
"Your settings are already saved — closing now is safe."
msgstr ""
"تتبدّل الطبقة إلى اللغة الجديدة في المرة التالية التي تفتح فيها التطبيق. تم "
"حفظ إعداداتك بالفعل — الإغلاق الآن آمن."

#. Language --------------------------------------------------------------
#: src/frontend/keysclicks-window.c:561 src/frontend/keysclicks-window.c:972
msgid "Language"
msgstr "اللغة"

#: src/frontend/keysclicks-window.c:572 src/frontend/keysclicks-window.c:620
msgid "System (default)"
msgstr "النظام (افتراضي)"

#: src/frontend/keysclicks-window.c:602
msgid "Keyboard layout"
msgstr "تخطيط لوحة المفاتيح"

#: src/frontend/keysclicks-window.c:670
msgid "Automatic"
msgstr "تلقائي"

#: src/frontend/keysclicks-window.c:676
#, c-format
msgid "Monitor %u"
msgstr "الشاشة %u"

#: src/frontend/keysclicks-window.c:695
msgid "Overlay monitor"
msgstr "شاشة الطبقة"

#: src/frontend/keysclicks-window.c:726
msgid "Pin to dock"
msgstr "تثبيت في الرصيف"

#: src/frontend/keysclicks-window.c:726
msgid "Unpin from dock"
msgstr "إلغاء التثبيت من الرصيف"

#: src/frontend/keysclicks-window.c:728
msgid "Remove this app from the COSMIC dock"
msgstr "إزالة هذا التطبيق من رصيف COSMIC"

#: src/frontend/keysclicks-window.c:729
msgid "Pin this app to the COSMIC dock"
msgstr "تثبيت هذا التطبيق في رصيف COSMIC"

#: src/frontend/keysclicks-window.c:767
msgid "None — click Set, then hold a shortcut (e.g. Ctrl+Shift+H)"
msgstr ""
"لا شيء — انقر على تعيين، ثم اضغط مع الاستمرار على اختصار (مثل Ctrl+Shift+H)"

#: src/frontend/keysclicks-window.c:795 src/frontend/keysclicks-window.c:874
msgid "Press keys…"
msgstr "اضغط المفاتيح…"

#: src/frontend/keysclicks-window.c:795 src/frontend/keysclicks-window.c:1009
msgid "Set"
msgstr "تعيين"

#: src/frontend/keysclicks-window.c:825
msgid "Hold the shortcut…  "
msgstr "اضغط مع الاستمرار على الاختصار…  "

#: src/frontend/keysclicks-window.c:873
msgid "Hold the shortcut, then release to save. Esc cancels."
msgstr "اضغط مع الاستمرار على الاختصار، ثم حرِّره للحفظ. مفتاح Esc يُلغي."

#: src/frontend/keysclicks-window.c:917 src/frontend/keysclicks-window.c:930
msgid ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"
msgstr ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"

#. Privacy master toggle, prominent on the left of the header.
#: src/frontend/keysclicks-window.c:935
msgid "Hide keys"
msgstr "إخفاء المفاتيح"

#: src/frontend/keysclicks-window.c:938
msgid "Hide keystrokes (privacy): show • instead of keys"
msgstr "إخفاء ضغطات المفاتيح (الخصوصية): إظهار • بدلاً من المفاتيح"

#. overlay display layout, right below
#. Privacy ---------------------------------------------------------------
#: src/frontend/keysclicks-window.c:977
msgid "Privacy"
msgstr "الخصوصية"

#: src/frontend/keysclicks-window.c:979
msgid "Hide keystrokes (privacy)"
msgstr "إخفاء ضغطات المفاتيح (الخصوصية)"

#: src/frontend/keysclicks-window.c:988
msgid "Automatic password hiding"
msgstr "إخفاء كلمات المرور تلقائيًا"

#: src/frontend/keysclicks-window.c:996
msgid ""
"On (PRO) — passwords are hidden automatically in password fields. This "
"module is still in development."
msgstr ""
"مُفعّل (PRO) — تُخفى كلمات المرور تلقائيًا في حقول كلمات المرور. لا تزال هذه "
"الوحدة قيد التطوير."

#: src/frontend/keysclicks-window.c:998
msgid ""
"PRO — in development. Automatic hiding ships with the PRO add-on; the manual "
"\"Hide keys\" toggle/shortcut works now."
msgstr ""
"PRO — قيد التطوير. يأتي الإخفاء التلقائي مع إضافة PRO؛ أما مفتاح/اختصار "
"\"Hide keys\" اليدوي فيعمل الآن."

#: src/frontend/keysclicks-window.c:1007
msgid "Hide-keys shortcut"
msgstr "اختصار إخفاء المفاتيح"

#: src/frontend/keysclicks-window.c:1012
msgid "Click, then hold a key combination to assign it"
msgstr "انقر، ثم اضغط مع الاستمرار على تركيبة مفاتيح لتعيينها"

#: src/frontend/keysclicks-window.c:1021
msgid "System keyboard shortcuts"
msgstr "اختصارات لوحة المفاتيح للنظام"

#: src/frontend/keysclicks-window.c:1024
msgid "Global shortcuts are set in the OS — open COSMIC → Keyboard → Shortcuts"
msgstr ""
"تُضبط الاختصارات العامة في نظام التشغيل — افتح COSMIC → لوحة المفاتيح → "
"الاختصارات"

#: src/frontend/keysclicks-window.c:1026
msgid "Open settings"
msgstr "فتح الإعدادات"

