msgstr "Muda wa kuisha (ms)"

#: src/frontend/keysclicks-window.c:1020
msgid "Bar opacity (%)"
msgstr "Uwazi wa upau (%)"

#: src/frontend/main.c:107
msgid "Left Click"
msgstr "Bofya Kushoto"

#: src/frontend/main.c:109
