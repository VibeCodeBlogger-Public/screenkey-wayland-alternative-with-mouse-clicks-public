#: src/frontend/keysclicks-window.c:1005
msgid "Position and behaviour"
msgstr "Nafasi na tabia"

#: src/frontend/keysclicks-window.c:1006
msgid "Bottom"
msgstr "Chini"

#: src/frontend/keysclicks-window.c:1006
msgid "Top"
msgstr "Juu"

#: src/frontend/keysclicks-window.c:1007
msgid "Screen edge"
msgstr "Ukingo wa skrini"

