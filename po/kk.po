msgid "Left Click"
msgstr "Сол басу"

#: src/frontend/main.c:108
msgid "Right Click"
msgstr "Оң басу"

#: src/frontend/main.c:110
msgid "Middle Click"
msgstr "Орта басу"

#: src/frontend/main.c:122
#, c-format
msgid "Mouse(%u)"
msgstr "Тінтуір(%u)"

#: src/frontend/main.c:407
