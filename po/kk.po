#: src/frontend/keysclicks-window.c:905
msgid "Horizontal margin (%)"
msgstr "Көлденең жиек (%)"

#: src/frontend/keysclicks-window.c:907
msgid "Vertical margin (%)"
msgstr "Тік жиек (%)"

#: src/frontend/keysclicks-window.c:910
msgid "Keep visible (no timeout)"
msgstr "Көрініп тұрсын (уақыт бітпейді)"

#: src/frontend/keysclicks-window.c:913
msgid "Timeout (ms)"
msgstr "Күту уақыты (ms)"

#: src/frontend/keysclicks-window.c:916
msgid "Bar opacity (%)"
msgstr "Панель мөлдірлігі (%)"

