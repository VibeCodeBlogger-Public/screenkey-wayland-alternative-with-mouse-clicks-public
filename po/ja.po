#: src/frontend/keysclicks-feedback.c:303
msgid "Screenshot attached."
msgstr "スクリーンショットを添付しました。"

#: src/frontend/keysclicks-feedback.c:307
msgid "Screenshot unavailable — your description still helps."
msgstr "スクリーンショットを取得できません — 説明だけでも役立ちます。"

#: src/frontend/keysclicks-feedback.c:414
#, c-format
msgid "Report #%s sent — thank you!"
msgstr "レポート #%s を送信しました — ありがとうございます！"

#: src/frontend/keysclicks-feedback.c:416
msgid "Report sent — thank you!"
msgstr "レポートを送信しました — ありがとうございます！"

#: src/frontend/keysclicks-feedback.c:424
msgid "Could not send your report."
msgstr "レポートを送信できませんでした。"

#: src/frontend/keysclicks-feedback.c:428
msgid "Network error — please try again."
msgstr "ネットワークエラー — もう一度お試しください。"

#: src/frontend/keysclicks-feedback.c:451
msgid "Capturing screenshot…"
msgstr "スクリーンショットを撮影中…"

#: src/frontend/keysclicks-feedback.c:502
msgid "Sending…"
msgstr "送信中…"

#: src/frontend/keysclicks-feedback.c:541
#: src/frontend/keysclicks-feedback.c:557
msgid "Report a bug or idea"
msgstr "バグや改善案を報告"

#: src/frontend/keysclicks-feedback.c:565
msgid "🐞 Bug"
msgstr "🐞 バグ"

#: src/frontend/keysclicks-feedback.c:566
msgid "💡 Idea"
msgstr "💡 アイデア"

#: src/frontend/keysclicks-feedback.c:574
msgid "What happened? (optional)"
msgstr "何が起きましたか？（任意）"

#: src/frontend/keysclicks-feedback.c:593
msgid "Attach screenshot of my screen"
msgstr "画面のスクリーンショットを添付"

#: src/frontend/keysclicks-feedback.c:598
msgid "A screenshot may show sensitive on-screen content. Off by default."
msgstr ""
"スクリーンショットには画面上の機密情報が写る場合があります。既定ではオフで"
"す。"

#: src/frontend/keysclicks-feedback.c:612
msgid "Attach diagnostics (build, OS, monitors)"
msgstr "診断情報を添付（ビルド、OS、モニター）"

#: src/frontend/keysclicks-feedback.c:626
msgid "Cancel"
msgstr "キャンセル"

#: src/frontend/keysclicks-feedback.c:628
msgid "Send"
msgstr "送信"

#: src/frontend/keysclicks-feedback.c:651
msgid "Report a bug"
msgstr "バグを報告"

#: src/frontend/keysclicks-overlay.c:404
msgid "On-Screen Keys & Clicks Visualizer"
msgstr "オンスクリーン キー＆クリック ビジュアライザー"

#: src/frontend/keysclicks-window.c:141
msgid "Close to switch monitor"
msgstr "閉じてモニターを切り替え"

#: src/frontend/keysclicks-window.c:142
msgid ""
"The overlay moves to the new monitor the next time you open the app. Your "
"settings are already saved — closing now is safe."
msgstr ""
"次回アプリを開いたときに、オーバーレイが新しいモニターに移動します。設定はす"
"でに保存されています — 今すぐ閉じても安全です。"

#: src/frontend/keysclicks-window.c:152
msgid "Close"
msgstr "閉じる"

#. Language --------------------------------------------------------------
#: src/frontend/keysclicks-window.c:521 src/frontend/keysclicks-window.c:932
msgid "Language"
msgstr "言語"

#: src/frontend/keysclicks-window.c:532 src/frontend/keysclicks-window.c:580
msgid "System (default)"
msgstr "システム（既定）"

#: src/frontend/keysclicks-window.c:562
msgid "Keyboard layout"
msgstr "キーボードレイアウト"

#: src/frontend/keysclicks-window.c:630
msgid "Automatic"
msgstr "自動"

#: src/frontend/keysclicks-window.c:636
#, c-format
msgid "Monitor %u"
msgstr "モニター %u"

#: src/frontend/keysclicks-window.c:655
msgid "Overlay monitor"
msgstr "オーバーレイのモニター"

#: src/frontend/keysclicks-window.c:686
msgid "Pin to dock"
msgstr "ドックに固定"

#: src/frontend/keysclicks-window.c:686
msgid "Unpin from dock"
msgstr "ドックの固定を解除"

#: src/frontend/keysclicks-window.c:688
msgid "Remove this app from the COSMIC dock"
msgstr "このアプリを COSMIC ドックから削除"

#: src/frontend/keysclicks-window.c:689
msgid "Pin this app to the COSMIC dock"
msgstr "このアプリを COSMIC ドックに固定"

#: src/frontend/keysclicks-window.c:727
msgid "None — click Set, then hold a shortcut (e.g. Ctrl+Shift+H)"
msgstr ""
"なし —「設定」をクリックしてからショートカットを押し続けてください（例: "
"Ctrl+Shift+H）"

#: src/frontend/keysclicks-window.c:755 src/frontend/keysclicks-window.c:834
msgid "Press keys…"
msgstr "キーを押してください…"

#: src/frontend/keysclicks-window.c:755 src/frontend/keysclicks-window.c:969
msgid "Set"
msgstr "設定"

#: src/frontend/keysclicks-window.c:785
msgid "Hold the shortcut…  "
msgstr "ショートカットを押し続けてください…  "

#: src/frontend/keysclicks-window.c:833
msgid "Hold the shortcut, then release to save. Esc cancels."
msgstr ""
"ショートカットを押し続けてから離すと保存されます。Esc でキャンセルします。"

#: src/frontend/keysclicks-window.c:877 src/frontend/keysclicks-window.c:890
msgid ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"
msgstr ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"

#. Privacy master toggle, prominent on the left of the header.
#: src/frontend/keysclicks-window.c:895
msgid "Hide keys"
msgstr "キーを非表示"

#: src/frontend/keysclicks-window.c:898
msgid "Hide keystrokes (privacy): show • instead of keys"
msgstr "キー入力を非表示（プライバシー）: キーの代わりに • を表示"

#. overlay display layout, right below
#. Privacy ---------------------------------------------------------------
#: src/frontend/keysclicks-window.c:937
msgid "Privacy"
msgstr "プライバシー"

#: src/frontend/keysclicks-window.c:939
msgid "Hide keystrokes (privacy)"
msgstr "キー入力を非表示（プライバシー）"

#: src/frontend/keysclicks-window.c:948
msgid "Automatic password hiding"
msgstr "パスワードの自動非表示"

#: src/frontend/keysclicks-window.c:956
msgid ""
"On (PRO) — passwords are hidden automatically in password fields. This "
"module is still in development."
msgstr ""
"オン（PRO）— パスワード欄でパスワードが自動的に非表示になります。このモジュー"
"ルはまだ開発中です。"

#: src/frontend/keysclicks-window.c:958
msgid ""
"PRO — in development. Automatic hiding ships with the PRO add-on; the manual "
"\"Hide keys\" toggle/shortcut works now."
msgstr ""
"PRO — 開発中。自動非表示は PRO アドオンで提供されます。手動の「Hide keys」ト"
"グル/ショートカットは現在ご利用いただけます。"

#: src/frontend/keysclicks-window.c:967
msgid "Hide-keys shortcut"
msgstr "キー非表示のショートカット"

#: src/frontend/keysclicks-window.c:972
msgid "Click, then hold a key combination to assign it"
msgstr "クリックしてからキーの組み合わせを押し続けて割り当てます"

#: src/frontend/keysclicks-window.c:981
msgid "System keyboard shortcuts"
msgstr "システムのキーボードショートカット"

#: src/frontend/keysclicks-window.c:984
msgid "Global shortcuts are set in the OS — open COSMIC → Keyboard → Shortcuts"
msgstr ""
"グローバルショートカットは OS で設定します — COSMIC → キーボード → ショート"
"カット を開いてください"

#: src/frontend/keysclicks-window.c:986
msgid "Open settings"
msgstr "設定を開く"

