#: src/frontend/keysclicks-window.c:893
msgid "Show keyboard"
msgstr "Pokaż klawiaturę"

#: src/frontend/keysclicks-window.c:895
msgid "Show mouse"
msgstr "Pokaż mysz"

#: src/frontend/keysclicks-window.c:896
msgid "Show Shift separately"
msgstr "Pokaż Shift osobno"

#: src/frontend/keysclicks-window.c:898
msgid "Draw border"
msgstr "Rysuj obramowanie"

#. Position & behaviour --------------------------------------------------
#: src/frontend/keysclicks-window.c:901
msgid "Position and behaviour"
msgstr "Pozycja i zachowanie"

#: src/frontend/keysclicks-window.c:902
msgid "Bottom"
msgstr "Dół"

#: src/frontend/keysclicks-window.c:902
msgid "Top"
msgstr "Góra"

#: src/frontend/keysclicks-window.c:903
msgid "Screen edge"
msgstr "Krawędź ekranu"

#. Margins are PERCENT (zoom/resolution independent). Horizontal is bidirectional.
#: src/frontend/keysclicks-window.c:905
msgid "Horizontal margin (%)"
msgstr "Margines poziomy (%)"

#: src/frontend/keysclicks-window.c:907
msgid "Vertical margin (%)"
msgstr "Margines pionowy (%)"

#: src/frontend/keysclicks-window.c:910
msgid "Keep visible (no timeout)"
msgstr "Zawsze widoczny (bez limitu czasu)"

#: src/frontend/keysclicks-window.c:913
msgid "Timeout (ms)"
msgstr "Limit czasu (ms)"

#: src/frontend/keysclicks-window.c:916
msgid "Bar opacity (%)"
msgstr "Krycie paska (%)"

#: src/frontend/main.c:106
msgid "Left Click"
msgstr "Lewe kliknięcie"

#: src/frontend/main.c:108
