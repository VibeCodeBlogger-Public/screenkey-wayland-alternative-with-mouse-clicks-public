#: src/frontend/keysclicks-window.c:1031
msgid "Show keyboard"
msgstr "Показувати клавіатуру"

#: src/frontend/keysclicks-window.c:1033
msgid "Show mouse"
msgstr "Показувати мишу"

#: src/frontend/keysclicks-window.c:1034
