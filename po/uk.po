msgid "Horizontal margin (%)"
msgstr "Горизонтальний відступ (%)"

#: src/frontend/keysclicks-window.c:1045
msgid "Vertical margin (%)"
msgstr "Вертикальний відступ (%)"

#: src/frontend/keysclicks-window.c:1048
msgid "Keep visible (no timeout)"
msgstr "Завжди показувати (без тайм-ауту)"

#: src/frontend/keysclicks-window.c:1051
msgid "Timeout (ms)"
msgstr "Тайм-аут (ms)"

#: src/frontend/keysclicks-window.c:1054
