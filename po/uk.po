#: src/frontend/keysclicks-feedback.c:303
msgid "Screenshot attached."
msgstr "Знімок екрана додано."

#: src/frontend/keysclicks-feedback.c:307
msgid "Screenshot unavailable — your description still helps."
msgstr "Знімок екрана недоступний — ваш опис усе одно допоможе."

#: src/frontend/keysclicks-feedback.c:414
#, c-format
msgid "Report #%s sent — thank you!"
msgstr "Звіт #%s надіслано — дякуємо!"

#: src/frontend/keysclicks-feedback.c:416
msgid "Report sent — thank you!"
msgstr "Звіт надіслано — дякуємо!"

#: src/frontend/keysclicks-feedback.c:424
msgid "Could not send your report."
msgstr "Не вдалося надіслати звіт."

#: src/frontend/keysclicks-feedback.c:428
msgid "Network error — please try again."
msgstr "Помилка мережі — спробуйте ще раз."

#: src/frontend/keysclicks-feedback.c:451
msgid "Capturing screenshot…"
msgstr "Створення знімка екрана…"

#: src/frontend/keysclicks-feedback.c:502
msgid "Sending…"
msgstr "Надсилання…"

#: src/frontend/keysclicks-feedback.c:541
#: src/frontend/keysclicks-feedback.c:557
msgid "Report a bug or idea"
msgstr "Повідомити про помилку чи ідею"

#: src/frontend/keysclicks-feedback.c:565
msgid "🐞 Bug"
msgstr "🐞 Помилка"

#: src/frontend/keysclicks-feedback.c:566
msgid "💡 Idea"
msgstr "💡 Ідея"

#: src/frontend/keysclicks-feedback.c:574
msgid "What happened? (optional)"
msgstr "Що сталося? (необов’язково)"

#: src/frontend/keysclicks-feedback.c:593
msgid "Attach screenshot of my screen"
msgstr "Додати знімок мого екрана"

#: src/frontend/keysclicks-feedback.c:598
msgid "A screenshot may show sensitive on-screen content. Off by default."
msgstr ""
"Знімок екрана може містити конфіденційний вміст з екрана. За замовчуванням "
"вимкнено."

#: src/frontend/keysclicks-feedback.c:612
msgid "Attach diagnostics (build, OS, monitors)"
msgstr "Додати діагностику (збірка, ОС, монітори)"

#: src/frontend/keysclicks-feedback.c:626
msgid "Cancel"
msgstr "Скасувати"

#: src/frontend/keysclicks-feedback.c:628
msgid "Send"
msgstr "Надіслати"

#: src/frontend/keysclicks-feedback.c:651
msgid "Report a bug"
msgstr "Повідомити про помилку"

#: src/frontend/keysclicks-overlay.c:404
msgid "On-Screen Keys & Clicks Visualizer"
msgstr "Екранний візуалізатор клавіш і кліків"

#: src/frontend/keysclicks-window.c:141
msgid "Close to switch monitor"
msgstr "Закрийте, щоб змінити монітор"

#: src/frontend/keysclicks-window.c:142
msgid ""
"The overlay moves to the new monitor the next time you open the app. Your "
"settings are already saved — closing now is safe."
msgstr ""
"Оверлей переміститься на новий монітор під час наступного відкриття "
"застосунку. Ваші налаштування вже збережено — закривати зараз безпечно."

#: src/frontend/keysclicks-window.c:152 src/frontend/keysclicks-window.c:180
msgid "Close"
msgstr "Закрити"

#: src/frontend/keysclicks-window.c:169
msgid "Close to switch language"
msgstr "Закрийте, щоб змінити мову"

#: src/frontend/keysclicks-window.c:170
msgid ""
"The overlay switches to the new language the next time you open the app. "
"Your settings are already saved — closing now is safe."
msgstr "Оверлей перемкнеться на нову мову під час наступного відкриття застосунку. Ваші налаштування вже збережено — закривати зараз безпечно."

#. Language --------------------------------------------------------------
#: src/frontend/keysclicks-window.c:555 src/frontend/keysclicks-window.c:966
msgid "Language"
msgstr "Мова"

#: src/frontend/keysclicks-window.c:566 src/frontend/keysclicks-window.c:614
msgid "System (default)"
msgstr "Системна (за замовчуванням)"

#: src/frontend/keysclicks-window.c:596
msgid "Keyboard layout"
msgstr "Розкладка клавіатури"

#: src/frontend/keysclicks-window.c:664
msgid "Automatic"
msgstr "Автоматично"

#: src/frontend/keysclicks-window.c:670
#, c-format
msgid "Monitor %u"
msgstr "Монітор %u"

#: src/frontend/keysclicks-window.c:689
msgid "Overlay monitor"
msgstr "Монітор оверлея"

#: src/frontend/keysclicks-window.c:720
msgid "Pin to dock"
msgstr "Закріпити в доку"

#: src/frontend/keysclicks-window.c:720
msgid "Unpin from dock"
msgstr "Відкріпити з доку"

#: src/frontend/keysclicks-window.c:722
msgid "Remove this app from the COSMIC dock"
msgstr "Видалити цей застосунок з доку COSMIC"

#: src/frontend/keysclicks-window.c:723
msgid "Pin this app to the COSMIC dock"
msgstr "Закріпити цей застосунок у доку COSMIC"

#: src/frontend/keysclicks-window.c:761
msgid "None — click Set, then hold a shortcut (e.g. Ctrl+Shift+H)"
msgstr ""
"Не задано — натисніть «Задати», потім утримуйте сполучення (напр. "
"Ctrl+Shift+H)"

#: src/frontend/keysclicks-window.c:789 src/frontend/keysclicks-window.c:868
msgid "Press keys…"
msgstr "Натисніть клавіші…"

#: src/frontend/keysclicks-window.c:789 src/frontend/keysclicks-window.c:1003
msgid "Set"
msgstr "Задати"

#: src/frontend/keysclicks-window.c:819
msgid "Hold the shortcut…  "
msgstr "Утримуйте сполучення…  "

#: src/frontend/keysclicks-window.c:867
msgid "Hold the shortcut, then release to save. Esc cancels."
msgstr "Утримуйте сполучення, потім відпустіть, щоб зберегти. Esc — скасувати."

#: src/frontend/keysclicks-window.c:911 src/frontend/keysclicks-window.c:924
msgid ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"
msgstr ""
"On-Screen Keyboard & Mouse-Click Visualizer — Always-On-Top Overlay for "
"Linux/Wayland (COSMIC, sway, Hyprland, KDE Plasma, wlroots)"

#. Privacy master toggle, prominent on the left of the header.
#: src/frontend/keysclicks-window.c:929
msgid "Hide keys"
msgstr "Приховати клавіші"

#: src/frontend/keysclicks-window.c:932
msgid "Hide keystrokes (privacy): show • instead of keys"
msgstr "Приховати натискання (приватність): показувати • замість клавіш"

#. overlay display layout, right below
#. Privacy ---------------------------------------------------------------
#: src/frontend/keysclicks-window.c:971
msgid "Privacy"
msgstr "Приватність"

#: src/frontend/keysclicks-window.c:973
msgid "Hide keystrokes (privacy)"
msgstr "Приховати натискання (приватність)"

#: src/frontend/keysclicks-window.c:982
msgid "Automatic password hiding"
msgstr "Автоматичне приховування паролів"

#: src/frontend/keysclicks-window.c:990
msgid ""
"On (PRO) — passwords are hidden automatically in password fields. This "
"module is still in development."
msgstr ""
"Увімк (PRO) — паролі автоматично приховуються в полях пароля. Цей модуль ще "
"в розробці."

#: src/frontend/keysclicks-window.c:992
msgid ""
"PRO — in development. Automatic hiding ships with the PRO add-on; the manual "
"\"Hide keys\" toggle/shortcut works now."
msgstr ""
"PRO — у розробці. Автоматичне приховування входить у доповнення PRO; ручний "
"перемикач/сполучення \"Hide keys\" працює вже зараз."

#: src/frontend/keysclicks-window.c:1001
msgid "Hide-keys shortcut"
msgstr "Сполучення для приховування клавіш"

#: src/frontend/keysclicks-window.c:1006
msgid "Click, then hold a key combination to assign it"
msgstr "Натисніть, потім утримуйте сполучення клавіш, щоб призначити його"

#: src/frontend/keysclicks-window.c:1015
msgid "System keyboard shortcuts"
msgstr "Системні комбінації клавіш"

#: src/frontend/keysclicks-window.c:1018
msgid "Global shortcuts are set in the OS — open COSMIC → Keyboard → Shortcuts"
msgstr ""
"Глобальні сполучення задаються в ОС — відкрийте COSMIC → Клавіатура → "
"Сполучення"

#: src/frontend/keysclicks-window.c:1020
msgid "Open settings"
msgstr "Відкрити налаштування"

