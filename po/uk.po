msgid "Bottom"
msgstr "Знизу"

#: src/frontend/keysclicks-window.c:1040
msgid "Top"
msgstr "Зверху"

#: src/frontend/keysclicks-window.c:1041
msgid "Screen edge"
msgstr "Край екрана"

