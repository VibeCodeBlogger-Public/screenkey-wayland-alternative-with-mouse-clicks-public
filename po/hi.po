msgid "Hide-keys shortcut"
msgstr "कुंजी छिपाने का शॉर्टकट"

#: src/frontend/keysclicks-window.c:1012
msgid "Click, then hold a key combination to assign it"
msgstr "क्लिक करें, फिर इसे असाइन करने के लिए कोई कुंजी संयोजन दबाए रखें"

