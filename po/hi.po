#: src/frontend/keysclicks-feedback.c:303
msgid "Screenshot attached."
msgstr "स्क्रीनशॉट संलग्न किया गया।"

#: src/frontend/keysclicks-feedback.c:307
msgid "Screenshot unavailable — your description still helps."
msgstr "स्क्रीनशॉट उपलब्ध नहीं — आपका विवरण फिर भी मदद करता है।"

