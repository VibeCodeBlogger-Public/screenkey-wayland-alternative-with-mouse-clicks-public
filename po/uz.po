msgid "Vertical margin (%)"
msgstr "Vertikal hoshiya (%)"

#: src/frontend/keysclicks-window.c:1048
msgid "Keep visible (no timeout)"
msgstr "Koʻrinib tursin (vaqt tugamaydi)"

#: src/frontend/keysclicks-window.c:1051
msgid "Timeout (ms)"
msgstr "Kutish vaqti (ms)"

#: src/frontend/keysclicks-window.c:1054
msgid "Bar opacity (%)"
msgstr "Panel shaffofligi (%)"

