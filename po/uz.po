msgstr "Joylashuv va harakat"

#: src/frontend/keysclicks-window.c:1040
msgid "Bottom"
msgstr "Pastki"

#: src/frontend/keysclicks-window.c:1040
msgid "Top"
msgstr "Yuqorigi"

#: src/frontend/keysclicks-window.c:1041
msgid "Screen edge"
msgstr "Ekran cheti"

