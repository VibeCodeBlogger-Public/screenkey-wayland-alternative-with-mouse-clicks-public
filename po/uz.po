#: src/frontend/keysclicks-window.c:1034
msgid "Show Shift separately"
msgstr "Shift ni alohida koʻrsatish"

#: src/frontend/keysclicks-window.c:1036
msgid "Draw border"
msgstr "Chegara chizish"

